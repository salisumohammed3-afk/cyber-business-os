{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/run-agent.ts": {
      "maxDuration": 120,
      "includeFiles": "api/agent-scripts/**"
    },
    "api/daily-digest.ts": {
      "maxDuration": 120
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/proactive-planner",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/daily-digest",
      "schedule": "5 8 * * *"
    },
    {
      "path": "/api/skill-recommender",
      "schedule": "10 8 * * *"
    }
  ]
}
